# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# GraphHopper API (optional - cloud routing)
GRAPHHOPPER_API_KEY=your-api-key

# JWT Secret - MUST change in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Upstash Redis (caching)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# VROOM & OSRM (Vehicle Routing Optimization)
# Start with: docker compose --profile routing up -d
VROOM_URL=http://localhost:5000
OSRM_URL=http://localhost:5001
VROOM_TIMEOUT=60000
OSRM_TIMEOUT=30000

# Cloudflare R2 Storage (S3-compatible)
# For evidence photos and file uploads
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# Centrifugo (realtime WebSocket server) - see ADR-0007
# Start with: docker compose up -d centrifugo
# CENTRIFUGO_URL is how the Next.js backend reaches Centrifugo's HTTP API
# (http://centrifugo:8000 inside the docker network, localhost when the app
# runs on the host with the port mapped).
CENTRIFUGO_URL=http://localhost:8000
CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=change-this-centrifugo-token-secret
CENTRIFUGO_API_KEY=change-this-centrifugo-api-key
CENTRIFUGO_ALLOWED_ORIGIN=http://localhost:3000
# Browser-facing WebSocket URL. In production leave it unset — the client
# derives a same-origin /connection/websocket served by the reverse proxy.
# In dev the app and Centrifugo are on different ports, so set it explicitly.
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket

# OneSignal push notifications (driver chat) - see ADR-0007
# From the OneSignal dashboard: Settings → Keys & IDs.
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
