# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — track the template so new devs (and future-you) know
# which vars exist; never track real values.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OSRM data files (large - download with docker/osrm/setup.sh)
docker/osrm/*.osm.pbf
docker/osrm/*.osrm*

# Sample data and optimization results (not source)
/example
/results

# Playwright MCP scratch artifacts
/.playwright-mcp
*.screenshot.png
01-existing-plan.png

# Claude Code harness scratch files
/.claude

# Local agent skills (per-developer, not project state)
.agents/skills/
skills-lock.json
